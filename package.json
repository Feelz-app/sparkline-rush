{
  "name": "sparkline-rush",
  "version": "1.2.0",
  "private": true,
  "description": "A sleek mobile-first arcade runner with missions, powerups, local leaderboards, and ad placements.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "tsc --noEmit",
    "ios:sync": "npm run build && npx cap sync ios",
    "skin:previews": "node scripts/generate-secret-skin-previews.mjs"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
